generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  surname    String?
  location   String?
  bggUsername String?
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  groupMemberships GroupMember[]
  votes            Vote[]
  addedGames       GroupGame[]
  createdGroups    Group[]        @relation("GroupCreator")
  createdSessions  GameSession[]  @relation("SessionCreator")
  createdEvents    Event[]        @relation("EventCreator")
  eventAttendances EventAttendee[]
  addedEventGames  EventGame[]    @relation("EventGameAdder")
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Group {
  id            String   @id @default(cuid())
  name          String
  createdAt     DateTime @default(now())
  createdById   String
  createdBy     User     @relation("GroupCreator", fields: [createdById], references: [id])
  inviteCode    String?  @unique
  inviteEnabled Boolean  @default(true)

  members     GroupMember[]
  invitations GroupInvitation[]
  games       GroupGame[]
  sessions    GameSession[]
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupInvitation {
  id        String   @id @default(cuid())
  groupId   String
  email     String
  token     String   @unique @default(cuid())
  status    String   @default("pending")
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([email])
}

model Game {
  id            String   @id @default(cuid())
  bggId         Int      @unique
  name          String
  thumbnail     String?
  yearPublished Int?
  minPlayers    Int?
  maxPlayers    Int?
  playingTime   Int?
  bggRating     Float?
  bggRank       Int?
  weight        Float?
  updatedAt     DateTime @updatedAt

  groupGames   GroupGame[]
  sessionGames GameSessionGame[]
  eventGames   EventGame[]
}

model GameSession {
  id           String   @id @default(cuid())
  groupId      String
  name         String?
  date         DateTime
  playerCount  Int
  totalMinutes Int
  status       String   @default("planned") // planned, playing, completed
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group     Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User              @relation("SessionCreator", fields: [createdById], references: [id])
  games     GameSessionGame[]

  @@index([groupId])
  @@index([date])
}

model GameSessionGame {
  id        String @id @default(cuid())
  sessionId String
  gameId    String
  order     Int
  status    String @default("pending") // pending, playing, completed, skipped

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  game    Game        @relation(fields: [gameId], references: [id])

  @@unique([sessionId, gameId])
}

model GroupGame {
  id        String   @id @default(cuid())
  groupId   String
  gameId    String
  addedById String
  addedAt   DateTime @default(now())

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  game    Game  @relation(fields: [gameId], references: [id])
  addedBy User  @relation(fields: [addedById], references: [id])
  votes   Vote[]

  @@unique([groupId, gameId])
  @@index([groupId])
}

model CollectionGame {
  id            String   @id @default(cuid())
  bggUsername   String
  bggId         Int
  name          String
  thumbnail     String?
  yearPublished Int?
  minPlayers    Int?
  maxPlayers    Int?
  bggRating     Float?
  bggRank       Int?
  weight        Float?
  playingTime   Int?
  numPlays      Int       @default(0)
  userRating    Float?
  bestWith      String?
  subtype       String    @default("boardgame") // boardgame | boardgameexpansion
  dateAdded     DateTime?
  fetchedAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([bggUsername, bggId])
  @@index([bggUsername])
  @@index([bggRank])
  @@index([bggRating])
  @@index([numPlays])
  @@index([dateAdded])
  @@index([subtype])
}

model Vote {
  id          String   @id @default(cuid())
  groupGameId String
  userId      String
  type        String   @default("up")
  createdAt   DateTime @default(now())

  groupGame GroupGame @relation(fields: [groupGameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([groupGameId, userId])
  @@index([groupGameId])
  @@index([userId])
}

model Event {
  id           String    @id @default(cuid())
  name         String
  description  String?
  date         DateTime
  endDate      DateTime?
  location     String?
  maxAttendees Int?
  visibility   String    @default("public") // public | private
  inviteCode   String?   @unique
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdBy User            @relation("EventCreator", fields: [createdById], references: [id])
  games     EventGame[]
  attendees EventAttendee[]

  @@index([date])
  @@index([visibility])
}

model EventGame {
  id        String   @id @default(cuid())
  eventId   String
  gameId    String
  addedById String
  addedAt   DateTime @default(now())

  event     Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  game      Game                @relation(fields: [gameId], references: [id])
  addedBy   User                @relation("EventGameAdder", fields: [addedById], references: [id])
  interests EventGameInterest[]

  @@unique([eventId, gameId])
  @@index([eventId])
}

model EventAttendee {
  id       String   @id @default(cuid())
  eventId  String
  userId   String
  status   String   @default("attending") // attending | maybe | cancelled
  joinedAt DateTime @default(now())

  event     Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id])
  interests EventGameInterest[]

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventGameInterest {
  id          String   @id @default(cuid())
  eventGameId String
  attendeeId  String
  intensity   Int      // 1-5
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventGame EventGame     @relation(fields: [eventGameId], references: [id], onDelete: Cascade)
  attendee  EventAttendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@unique([eventGameId, attendeeId])
  @@index([eventGameId])
  @@index([attendeeId])
}
